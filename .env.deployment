# Production deployment environment for Recon backend
# Fill secrets from your secret manager or current local .env before deploying.

PROJECT_NAME=RECON
MODE=production

APP_BASE_URL=https://reconhq.tech
API_BASE_URL=https://api.reconhq.tech
FRONTEND_REDIRECT_AFTER_LOGIN=https://reconhq.tech/auth/callback
ALLOWED_ORIGINS=["https://reconhq.tech","https://www.reconhq.tech"]
TRUSTED_HOSTS=["reconhq.tech","www.reconhq.tech","api.reconhq.tech"]

SESSION_COOKIE_NAME=recon_session
SESSION_MAX_AGE_SECONDS=600
SESSION_SAME_SITE=lax
SESSION_HTTPS_ONLY=true

SECRET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.reconhq.tech/api/v1/auth/google/callback

DATABASE_HOST=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_PORT=5432
ASYNC_DATABASE_URI=

REDIS_URL=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=Production

FCM_SERVER_KEY=
FCM_TOPIC=participants

BOOTSTRAP_ADMIN_EMAILS=
OPENAI_API_KEY=
