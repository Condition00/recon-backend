# ── App ───────────────────────────────────────────────────────
MODE=development                        # development | production | testing
SECRET_KEY=replace-with-random-string   # used for JWT signing and session middleware
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
FRONTEND_REDIRECT_AFTER_LOGIN=http://localhost:5173/auth/callback
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000","http://testserver"]
TRUSTED_HOSTS=["localhost","127.0.0.1","testserver","*.localhost"]
SESSION_COOKIE_NAME=recon_session
SESSION_MAX_AGE_SECONDS=600
SESSION_SAME_SITE=lax
SESSION_HTTPS_ONLY=false

# ── Database ──────────────────────────────────────────────────
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=recon_db
# Leave ASYNC_DATABASE_URI blank — it is assembled automatically from the fields above
ASYNC_DATABASE_URI=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Leave blank in development — defaults to http://localhost:8000/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=

# ── Cloudflare R2 ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Observability ─────────────────────────────────────────────
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=Staging

# ── Realtime Push (optional) ──────────────────────────────────
FCM_SERVER_KEY=
FCM_TOPIC=participants

# ── Bootstrap admins (comma-separated emails) ─────────────────
BOOTSTRAP_ADMIN_EMAILS=

# ── OpenAI (optional) ─────────────────────────────────────────
OPENAI_API_KEY=
